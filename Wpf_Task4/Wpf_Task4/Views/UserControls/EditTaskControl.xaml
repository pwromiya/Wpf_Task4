<UserControl x:Class="Wpf_Task4.UI.Views.UserControls.EditTaskControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:Wpf_Task4.Domain.Models;assembly=Wpf_Task4.Domain">

    <Border Background="White"
            BorderBrush="Black"
            BorderThickness="2"
            Padding="20"
            Width="420">

        <StackPanel>

            <!-- Title -->
            <TextBlock Text="{Binding DialogTitle}"
                       FontWeight="Bold"
                       FontSize="18"
                       Margin="0,0,0,15"/>

            <!-- Title -->
            <TextBlock Text="{DynamicResource TaskName}"
                       FontWeight="SemiBold"/>
            <TextBox Text="{Binding Title, Mode=TwoWay}"
                     Margin="0,5,0,10"/>

            <!-- Description -->
            <TextBlock Text="{DynamicResource Desc}"
                       FontWeight="SemiBold"/>
            <TextBox Text="{Binding Description, Mode=TwoWay}"
                     AcceptsReturn="True"
                     Height="100"
                     TextWrapping="Wrap"
                     Margin="0,5,0,10"/>
            
            <ComboBox ItemsSource="{Binding Statuses}"
                SelectedItem="{Binding Status, Mode=TwoWay}" />

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,15,0,0">

                <Button Content="{DynamicResource Cancel}"
                        Command="{Binding CancelCommand}"
                        Margin="0,0,10,0"/>

                <Button Content="{DynamicResource Save}"
                        Command="{Binding SaveCommand}"/>
            </StackPanel>

        </StackPanel>

    </Border>
</UserControl>