<!-- Registration window view -->
<Window x:Class="Wpf_Task4.UI.Views.RegisterView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Wpf_Task4.UI.Views.UserControls"
        Title="{DynamicResource Register}" 
        MinWidth="250"
        MinHeight="350"
        MaxWidth="350"
        MaxHeight="550"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <StackPanel Margin="20" VerticalAlignment="Center">
        <!-- Language selection buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <local:LanguageSwitcher/>
        </StackPanel>

        <!-- Login input field -->
        <TextBlock Text="{DynamicResource Login}"/>
        <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>

        <!-- Password input field -->
        <TextBlock Text="{DynamicResource Password}"/>
        <PasswordBox x:Name="PasswordBox" Margin="0,5"/>

        <!-- Registration button (code-behind handler) -->
        <Button Content="{DynamicResource Register}"
                Margin="0,10"
                Width="150" HorizontalAlignment="Center"
                Click="RegisterButton_Click"/>

        <!-- Navigation to login screen -->
        <Button Content="{DynamicResource InvitationToLogIn}"
                Margin="0,10"
                Command="{Binding OpenLoginCommand}" />
    </StackPanel>
</Window>